# 知识管理系统 V1.0 环境变量模板
# V1.0 使用 GBrain 关键词检索降级方案，不依赖向量嵌入/LLM 分块
# 向量嵌入、智能分块、MaaS 模型配置推迟到 V2.0

# ============================================
# V1.0 生效配置
# ============================================

# Brain 仓库路径
BRAIN_REPO=./brain

# 缓冲层配置
CACHE_DB_PATH=./cache/drafts.db
CONFLICT_DB_PATH=./cache/conflict-queue.db

# MCP 接口端口
MCP_QUERY_PORT=8100
MCP_WRITE_PORT=8101

# REST API 端口
REST_API_PORT=3000

# Dream Cycle 定时（crontab 格式）
DREAM_CYCLE_CRON=0 2 * * *

# 告警阈值
CONFLICT_ALERT_THRESHOLD=10
COMMIT_FAIL_ALERT_THRESHOLD=5
EMBED_FAIL_ALERT_THRESHOLD=3

# 过期草稿清理
STALE_DRAFT_DAYS=30

# ============================================
# V2.0 预留配置（V1.0 不生效，仅作模板）
# ============================================

# GBrain 内核 LLM 配置（向量嵌入/分块，非大模型调用）
# V2.0 接入 MaaS 或本地 embedding 服务时启用
# OPENAI_API_KEY=<your-maas-api-key>
# OPENAI_BASE_URL=https://api.icompify.com/v1

# MaaS 调用重试/超时/熔断配置
# MAAS_RETRY_COUNT=3
# MAAS_TIMEOUT_MS=30000
# MAAS_CIRCUIT_BREAKER_THRESHOLD=5
